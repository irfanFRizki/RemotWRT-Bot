#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/python3
SCRIPT=/usr/bin/pi4Bot.py
PIDFILE=/var/run/remotbot.pid

install_deps() {
    command -v pip3 >/dev/null 2>&1 || opkg install python3-pip 2>/dev/null || true
    pip3 show python-telegram-bot >/dev/null 2>&1 || \
        pip3 install "python-telegram-bot" --quiet 2>&1 | logger -t remotbot
    pip3 show requests >/dev/null 2>&1 || \
        pip3 install requests --quiet 2>&1 | logger -t remotbot
}

start_service() {
    local ENABLED=$(uci -q get remotbot.main.enabled 2>/dev/null)
    [ "$ENABLED" = "1" ] || {
        echo "[RemotBot] Disabled. Enable via LuCI: Services > Remot Bot > Settings"
        return 0
    }

    local TOKEN=$(uci -q get remotbot.main.bot_token 2>/dev/null)
    [ -n "$TOKEN" ] || {
        echo "[RemotBot] ERROR: Bot token belum diset!"
        return 1
    }

    install_deps

    procd_open_instance
    procd_set_param command $PROG $SCRIPT
    procd_set_param pidfile $PIDFILE
    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param user root
    procd_close_instance
}

stop_service() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        [ -n "$PID" ] && kill -TERM "$PID" 2>/dev/null
        sleep 2
        [ -n "$PID" ] && kill -9 "$PID" 2>/dev/null
        rm -f "$PIDFILE"
    fi
}

status() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            echo "RemotWRT Bot is running (PID: $PID)"
            return 0
        fi
    fi
    echo "RemotWRT Bot is not running"
    return 1
}
