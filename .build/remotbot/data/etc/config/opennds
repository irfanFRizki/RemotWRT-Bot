# OpenNDS Configuration with FAS (Forwarding Authentication Service)
# Untuk integrasi dengan RemotWRT-Bot captive portal

config opennds 'opennds'
    option enabled '1'
    
    # Gateway identification
    option gatewayname 'RemotWRT-Gateway'
    
    # FAS configuration - Level 0 (clear text, untuk internal network)
    # Catatan keamanan: fas_secure_enabled='0' karena ini captive portal internal
    # Bisa di-upgrade ke level 1 (hashed token) kalau dipakai di jaringan lebih terbuka
    option fas_secure_enabled '0'
    
    # FAS server URL (localhost, port dari remotbot.main.fas_port)
    option fas_port '2080'
    option fas_url 'http://127.0.0.1:2080/fas'
    
    # Pre-authentication behavior
    # 'block' = device belum auth benar-benar tidak dapat akses internet
    option preauth_idleaction 'block'
    
    # Whitelist port yang tetap bisa diakses sebelum authenticated
    # Port 53 (DNS) wajib supaya resolusi domain jalan untuk splash page
    # Port FAS (2080) wajib supaya redirect ke splash page jalan
    list fas_whitelist 'tcp 53'
    list fas_whitelist 'udp 53'
    list fas_whitelist 'tcp 2080'
    
    # Network settings
    option clientinterface 'br-lan'
    
    # Session timeout (detik) - user harus re-auth setelah ini
    option session_timeout '86400'
    
    # Idle timeout (detik) - session berakhir jika tidak ada aktivitas
    option idle_timeout '3600'
    
    # Log level
    option log_level 'info'
    
    # Custom splash directory (optional, FAS override ini)
    # option splash_template '/etc/opennds/splash.html'
