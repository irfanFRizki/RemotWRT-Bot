#!/bin/sh
# RemotWRT Bot - Dependency Installer
# Dipanggil saat instalasi IPK

LOG="/tmp/remotbot-install.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG"
}

install_pip_pkg() {
    PKG=$1
    log "Checking pip package: $PKG"
    python3 -c "import $PKG" 2>/dev/null && { log "$PKG already installed"; return 0; }
    log "Installing $PKG via pip..."
    pip3 install "$PKG" --break-system-packages >> "$LOG" 2>&1 && log "$PKG installed OK" || log "WARNING: Failed to install $PKG"
}

log "=== RemotWRT Bot Dependency Installer ==="

# Update opkg
log "Updating opkg..."
opkg update >> "$LOG" 2>&1

# Install python3 and pip
for PKG in python3 python3-pip python3-requests; do
    log "Checking opkg package: $PKG"
    opkg list-installed | grep -q "^$PKG " && { log "$PKG already installed"; continue; }
    log "Installing $PKG via opkg..."
    opkg install "$PKG" >> "$LOG" 2>&1 && log "$PKG installed OK" || log "WARNING: opkg install $PKG failed"
done

# Install python pip packages
install_pip_pkg "telegram"        # python-telegram-bot
install_pip_pkg "requests"

# Verify telegram bot package
python3 -c "from telegram.ext import Application" 2>/dev/null
if [ $? -ne 0 ]; then
    log "Installing python-telegram-bot from pip..."
    pip3 install "python-telegram-bot" --break-system-packages >> "$LOG" 2>&1
fi

# Create config dir
mkdir -p /etc/remotbot

# Create default config if not exists
if [ ! -f /etc/remotbot/config.json ]; then
    log "Creating default config..."
    cat > /etc/remotbot/config.json <<'EOF'
{
    "bot_token": "",
    "allowed_users": [],
    "cgi_online_path": "/www/cgi-bin/online"
}
EOF
fi

log "=== Installation complete. Configure via LuCI: Services > Remot Bot ==="
