#!/bin/sh
LOG="/tmp/remotbot-install.log"
log() { echo "[$(date '+%H:%M:%S')] $1" | tee -a "$LOG"; }
log "=== RemotWRT Bot Dependency Installer ==="
opkg update >> "$LOG" 2>&1
for PKG in python3 python3-pip python3-requests; do
    opkg list-installed | grep -q "^$PKG " || opkg install "$PKG" >> "$LOG" 2>&1
done
python3 -c "from telegram.ext import Application" 2>/dev/null || pip3 install "python-telegram-bot" --break-system-packages >> "$LOG" 2>&1
mkdir -p /etc/remotbot
[ ! -f /etc/remotbot/config.json ] && echo '{"bot_token":"","allowed_users":[],"cgi_online_path":"/www/cgi-bin/online","language":"id","cpu_temp_threshold":75,"ram_threshold":85,"wan_timeout_minutes":60,"mac_whitelist":[],"notify_cpu_temp":true,"notify_ram":true,"notify_wan":true,"notify_unknown_device":true}' > /etc/remotbot/config.json
log "=== Done. Configure: LuCI > Services > Remot Bot ==="
