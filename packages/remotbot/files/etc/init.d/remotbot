#!/bin/sh /etc/rc.common

START=99
STOP=10
USE_PROCD=1

PROG=/usr/bin/python3
SCRIPT=/usr/bin/pi4Bot.py
PIDFILE=/var/run/remotbot.pid

REQUIREMENTS=/usr/share/remotbot/requirements.txt

install_deps() {
    # Pastikan pip3 tersedia
    if ! command -v pip3 >/dev/null 2>&1; then
        logger -t remotbot "pip3 not found, trying opkg install python3-pip..."
        opkg install python3-pip 2>&1 | logger -t remotbot
        if ! command -v pip3 >/dev/null 2>&1; then
            logger -t remotbot "ERROR: pip3 masih tidak tersedia setelah install. Abort."
            return 1
        fi
    fi

    # Install dari requirements.txt (versi ter-pin)
    if [ ! -f "$REQUIREMENTS" ]; then
        logger -t remotbot "ERROR: $REQUIREMENTS tidak ditemukan. Package mungkin rusak."
        return 1
    fi

    # Cek apakah semua deps sudah terpasang (quick check)
    if pip3 show python-telegram-bot requests >/dev/null 2>&1; then
        return 0
    fi

    logger -t remotbot "Installing Python deps dari $REQUIREMENTS..."
    if ! pip3 install -r "$REQUIREMENTS" --quiet 2>&1 | logger -t remotbot; then
        logger -t remotbot "ERROR: pip3 install gagal. Bot mungkin tidak bisa start."
        return 1
    fi
    logger -t remotbot "Python deps berhasil diinstall."
}

start_service() {
    local ENABLED=$(uci -q get remotbot.main.enabled 2>/dev/null)
    [ "$ENABLED" = "1" ] || {
        echo "[RemotBot] Disabled. Enable via LuCI: Services > Remot Bot > Settings"
        return 0
    }

    local TOKEN=$(uci -q get remotbot.main.bot_token 2>/dev/null)
    [ -n "$TOKEN" ] || {
        echo "[RemotBot] ERROR: Bot token belum diset!"
        return 1
    }

    install_deps || {
        logger -t remotbot "ERROR: install_deps gagal. Service tidak dijalankan."
        return 1
    }

    # Ensure pending file exists and is owned by remotbot
    local PENDING_FILE=$(uci -q get remotbot.main.fas_pending_file 2>/dev/null || echo "/tmp/opennds_pending.json")
    touch "$PENDING_FILE" 2>/dev/null
    chown remotbot:remotbot "$PENDING_FILE" 2>/dev/null || true

    procd_open_instance
    procd_set_param command $PROG $SCRIPT
    procd_set_param pidfile $PIDFILE
    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param user remotbot
    procd_close_instance
}

stop_service() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        [ -n "$PID" ] && kill -TERM "$PID" 2>/dev/null
        sleep 2
        [ -n "$PID" ] && kill -9 "$PID" 2>/dev/null
        rm -f "$PIDFILE"
    fi
}

status() {
    if [ -f "$PIDFILE" ]; then
        PID=$(cat "$PIDFILE")
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            echo "RemotWRT Bot is running (PID: $PID)"
            return 0
        fi
    fi
    echo "RemotWRT Bot is not running"
    return 1
}
