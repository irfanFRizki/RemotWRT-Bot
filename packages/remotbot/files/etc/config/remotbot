config remotbot 'main'
	option bot_token ''
	option allowed_users ''
	option cgi_online_path '/www/cgi-bin/online'
	option enabled '0'
	option language 'id'
	option log_level 'INFO'
	option cpu_temp_threshold '75'
	option ram_threshold '85'
	option wan_timeout_minutes '60'
	option notify_cpu_temp '1'
	option notify_ram '1'
	option notify_wan '1'
	option notify_unknown_device '1'
	# list mac_whitelist 'aa:bb:cc:dd:ee:ff'
	# list blocked_macs 'xx:xx:xx:xx:xx:xx'
	
	# OpenNDS FAS configuration
	option fas_port '2080'
	option fas_pending_file '/tmp/opennds_pending.json'
	option fas_notify_ttl '300'
