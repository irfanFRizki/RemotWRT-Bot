{
  "luci-app-remotbot": {
    "description": "Grant access for RemotWRT Bot LuCI app",
    "read": {
      "uci": [ "remotbot" ],
      "ubus": { "service": ["list"], "rc": ["list"] }
    },
    "write": {
      "uci": [ "remotbot" ],
      "ubus": { "service": ["set","list","event","signal"], "rc": ["init"] }
    }
  }
}
